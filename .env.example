# Core model + API settings
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_BACKUP_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_HAIKU_MODEL=claude-haiku-4-5-20251001
OLLAMA_MODEL=guppy

# General runtime controls
GUPPY_DEV_MODE=0
GUPPY_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Web UI API endpoint
# Local development: /api (relative, proxied by vite dev server)
# Vercel production: https://your-vercel-domain.vercel.app/api
VITE_API_URL=/api

# Voice — Whisper STT model (base/small/medium/large-v2/large-v3)
# large-v3 is default — best accuracy, fits easily in 24GB VRAM
# Set to 'base' or 'small' if you need faster/lighter STT
GUPPY_WHISPER_MODEL=large-v3

# Voice personas (Kokoro-first, Windows SAPI fallback)
# Guppy: fast "wacky computer" cadence
GUPPY_TTS_VOICE=bm_lewis
GUPPY_TTS_RATE=+28%
GUPPY_TTS_PITCH=+12Hz
# Merlin: slower/deeper "wizard" cadence
MERLIN_TTS_VOICE=bm_lewis
MERLIN_TTS_RATE=-18%
MERLIN_TTS_PITCH=-14Hz
# Optional SAPI voice override for fallback mode only
GUPPY_SAPI_VOICE=Microsoft David Desktop
# Optional paid provider (recommended for highly consistent persona voices)
# GUPPY_TTS_PROVIDER=auto|kokoro|elevenlabs|sapi
GUPPY_TTS_PROVIDER=auto
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
# Set dedicated voice IDs if using ElevenLabs
ELEVENLABS_DEFAULT_VOICE_ID=
# You can also set these to ElevenLabs voice IDs per persona
# GUPPY_TTS_VOICE=
# MERLIN_TTS_VOICE=

# Semantic memory backend: sqlite (stable default) or chroma (advanced)
GUPPY_SEMANTIC_BACKEND=sqlite

# Search — Perplexity AI (free tier: pplx.ai/api, 5 req/min)
# Without this, search_web opens a browser tab instead of returning answers
PERPLEXITY_API_KEY=

# GitHub API (classic PAT or fine-grained token with repo access)
GITHUB_TOKEN=

# Weather — OpenWeatherMap (free: openweathermap.org/api, 1000 calls/day)
OPENWEATHERMAP_API_KEY=
WEATHER_LOCATION=Dallas,TX,US
WEATHER_UNITS=imperial

# Merlin tuning
MERLIN_HAIKU_BOOST=0
MERLIN_HAIKU_BOOST_MIN_CHARS=180
MERLIN_LOCAL_MODEL=merlin
MERLIN_LOCAL_BACKUP_MODEL=

# API / remote access
GUPPY_JWT_SECRET=replace-me
TURNSTILE_SECRET=replace-me

# Cloudflare Tunnel (Phase 3 remote access)
# 1. Run: bin\cloudflared.exe tunnel login
# 2. Run: bin\cloudflared.exe tunnel create guppy
# 3. Copy the UUID output into CLOUDFLARE_TUNNEL_ID
# 4. Set CLOUDFLARE_HOSTNAME to your subdomain (e.g. guppy.yourdomain.com)
# 5. Run: bin\cloudflared.exe tunnel route dns guppy guppy.yourdomain.com
# 6. Start tunnel: bin\start_tunnel.bat
CLOUDFLARE_TUNNEL_ID=
CLOUDFLARE_HOSTNAME=guppy.yourdomain.com

# Media integrations
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:8888/callback
YOUTUBE_API_KEY=
GMAIL_CREDENTIALS_PATH=
GOOGLE_CALENDAR_CREDENTIALS_PATH=

# External CRM stubs (activate as accounts are connected)
HUBSPOT_API_KEY=
SALESFORCE_ACCESS_TOKEN=
SALESFORCE_INSTANCE_URL=
GOHIGHLEVEL_API_KEY=
ZOHO_ACCESS_TOKEN=

# VoIP stubs (future live calling)
VOIP_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_T