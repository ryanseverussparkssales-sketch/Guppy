{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://guppy.local/schemas/voice_binding.schema.json",
  "title": "Guppy Voice Bindings",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "defaults", "bindings", "imports"],
  "properties": {
    "version": {"type": "integer", "minimum": 1},
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "required": ["engine", "voice_id"],
      "properties": {
        "engine": {"type": "string", "minLength": 1},
        "voice_id": {"type": "string", "minLength": 1}
      }
    },
    "bindings": {
      "type": "object",
      "additionalProperties": false,
      "required": ["by_model", "by_persona"],
      "properties": {
        "by_model": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "required": ["engine", "voice_id"],
            "properties": {
              "engine": {"type": "string", "minLength": 1},
              "voice_id": {"type": "string", "minLength": 1}
            }
          }
        },
        "by_persona": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "required": ["engine", "voice_id"],
            "properties": {
              "engine": {"type": "string", "minLength": 1},
              "voice_id": {"type": "string", "minLength": 1}
            }
          }
        }
      }
    },
    "imports": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "engine", "label", "source", "enabled"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9_\\-]{2,64}$"},
          "engine": {"type": "string", "minLength": 1},
          "label": {"type": "string", "minLength": 1},
          "source": {"type": "string", "minLength": 1},
          "sample_rate_hz": {"type": "integer", "minimum": 8000},
          "language": {"type": "string", "minLength": 2},
          "license": {"type": "string", "minLength": 1},
          "enabled": {"type": "boolean"}
        }
      }
    }
  }
}
