{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://guppy.local/schemas/persona.schema.json",
  "title": "Guppy Persona Config",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "default_persona_id", "personas", "assignments"],
  "properties": {
    "version": {"type": "integer", "minimum": 1},
    "default_persona_id": {"type": "string", "minLength": 1},
    "personas": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "scope", "system_prompt", "traits", "teaching"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9_\\-]{2,64}$"},
          "name": {"type": "string", "minLength": 2, "maxLength": 80},
          "scope": {"type": "string", "enum": ["global", "model"]},
          "model": {"type": "string", "minLength": 1},
          "system_prompt": {"type": "string", "minLength": 1, "maxLength": 4000},
          "profile_summary": {"type": "string", "minLength": 1, "maxLength": 4000},
          "traits": {
            "type": "object",
            "additionalProperties": false,
            "required": ["tone", "verbosity", "response_style"],
            "properties": {
              "tone": {"type": "string", "enum": ["butler", "casual", "analyst", "mentor", "custom"]},
              "verbosity": {"type": "string", "enum": ["low", "medium", "high"]},
              "response_style": {"type": "string", "enum": ["direct", "socratic", "structured", "narrative"]}
            }
          },
          "teaching": {
            "type": "object",
            "additionalProperties": false,
            "required": ["enabled", "socratic_bias", "example_bias"],
            "properties": {
              "enabled": {"type": "boolean"},
              "socratic_bias": {"type": "integer", "minimum": 0, "maximum": 100},
              "example_bias": {"type": "integer", "minimum": 0, "maximum": 100}
            }
          }
        },
        "allOf": [
          {
            "if": {"properties": {"scope": {"const": "model"}}},
            "then": {"required": ["model"]}
          }
        ]
      }
    },
    "assignments": {
      "type": "object",
      "additionalProperties": false,
      "required": ["global", "by_model"],
      "properties": {
        "global": {"type": "string", "minLength": 1},
        "by_model": {
          "type": "object",
          "additionalProperties": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
