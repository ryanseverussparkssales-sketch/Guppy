# Guppy Web UI — environment variables
#
# Copy this file to .env.local and uncomment/edit only what you need.
# Vite loads .env.local automatically (it is git-ignored).

# ── API base URL ──────────────────────────────────────────────────────────────
# Leave VITE_API_URL UNSET (or empty) for local development.
# The Vite dev server already proxies /api/*, /auth/*, /providers/*, etc.
# to http://localhost:8081 via the proxy config in vite.config.ts, so no
# absolute URL is needed here.
#
# Only set this if you are pointing the web UI at a remote or non-standard API:
# VITE_API_URL=http://my-remote-server:8081

# ── Dev server port ───────────────────────────────────────────────────────────
# Override the Vite dev-server port when 3000 is busy.
# Both vite.config.ts and playwright.config.ts read this variable so they stay
# in sync automatically.
#
# VITE_PORT=3003
